# Required — OpenRouter LLM access
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4

# Optional — enables web_search, web_crawl, fetch_url tools
FIRECRAWL_API_KEY=

# Optional — Telegram bot mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Optional — extra skill directories (semicolon-separated on Windows)
SKILLS_DIRS=

# Optional — name used in the startup TTS greeting
JARVIS_USER_NAME=
